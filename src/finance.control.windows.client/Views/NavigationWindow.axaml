<Window xmlns="https://github.com/avaloniaui"
        xmlns:rxui="http://reactiveui.net"
        xmlns:app="clr-namespace:finance.control.windows.client"
        xmlns:vm="using:finance.control.windows.client.ViewModels"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="finance.control.windows.client.Views.NavigationWindow"
        Title="FinanceControlApp"
        Width="1600" Height="900" MinWidth="1100" MinHeight="750"
        x:DataType="vm:NavigationViewModel">
        
  <DockPanel>
      <Border DockPanel.Dock="Bottom" 
              Padding="12" 
              BorderThickness="1">

		  <Grid ColumnDefinitions="*,*,*,*,*"
                HorizontalAlignment="Stretch">

              <Grid.Styles>
                  <Style Selector="Button.nav">
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                    <Setter Property="MinHeight" Value="44"/>
                    <Setter Property="Margin" Value="6,0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                  </Style>

                  <Style Selector="Button.add">
                      <Setter Property="HorizontalAlignment" Value="Center"/>
                      <Setter Property="VerticalAlignment" Value="Center"/>
                      <Setter Property="Margin" Value="6,0"/>
                      <Setter Property="FontSize" Value="24"/>
                      <Setter Property="FontWeight" Value="Bold"/>

                      <Setter Property="Width" Value="{Binding #NavRef.Bounds.Height}"/>
                      <Setter Property="Height" Value="{Binding #NavRef.Bounds.Height}"/>

                      <Setter Property="Foreground" Value="White"/>
                      <Setter Property="Background" Value="#3A3A3A"/>

                      <Setter Property="Template">
                        <ControlTemplate>
                          <Grid x:Name="Root"
                                RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                              <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>

                            <Grid.Transitions>
                              <Transitions>
                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.10"/>
                                <DoubleTransition Property="Opacity" Duration="0:1:0"/>
                              </Transitions>
                            </Grid.Transitions>

                            <Ellipse x:Name="Bg" Fill="{TemplateBinding Background}">
                              <Ellipse.Transitions>
                                <Transitions>
                                  <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
                                </Transitions>
                              </Ellipse.Transitions>
                            </Ellipse>

                            <ContentPresenter x:Name="Cp"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                          </Grid>
                        </ControlTemplate>
                      </Setter>
                    </Style>
            </Grid.Styles>

            <Button Grid.Column="0"
                    x:Name="NavRef"
                    Content="Записи"  
                    Command="{Binding GoPostsWindow}"
                    Classes="nav" />
            <Button Grid.Column="1" 
                    Content="Графики" 
                    Command="{Binding GoChartsWindow}"
                    Classes="nav" />
            <Button Grid.Column="2" 
                    Content="+" 
                    Command="{Binding GoAddCategoryWindow}"
                    Classes="add"/>
            <Button Grid.Column="3" 
                    Content="Отчеты" 
                    Command="{Binding GoReportsWindow}"
                    Classes="nav" />
            <Button Grid.Column="4" 
                    Content="Профиль" 
                    Command="{Binding GoProfileWindow}"
                    Classes="nav" />

      </Grid>
      </Border>

      <rxui:RoutedViewHost Grid.Row="1" Router="{Binding Router}" Margin="10">
      <rxui:RoutedViewHost.ViewLocator>
        <app:AppViewLocator />
      </rxui:RoutedViewHost.ViewLocator>
    </rxui:RoutedViewHost>

  </DockPanel>

</Window>
