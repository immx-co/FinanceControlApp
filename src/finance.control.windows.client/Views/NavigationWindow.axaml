<Window xmlns="https://github.com/avaloniaui"
        xmlns:rxui="http://reactiveui.net"
        xmlns:app="clr-namespace:finance.control.windows.client"
        xmlns:vm="using:finance.control.windows.client.ViewModels"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="finance.control.windows.client.Views.NavigationWindow"
        Title="FinanceControlApp"
        Width="1600" Height="900" MinWidth="1100" MinHeight="750"
        x:DataType="vm:NavigationViewModel">
        
  <DockPanel>
      <Border DockPanel.Dock="Bottom" Padding="12" BorderThickness="1">
		  <Grid ColumnDefinitions="*,*,*,*,*"
            HorizontalAlignment="Stretch">

            <Button Grid.Column="0" Content="Записи"  Command="{Binding GoPostsWindow}"  />
            <Button Grid.Column="1" Content="Графики" Command="{Binding GoChartsWindow}" />

      </Grid>
      </Border>

      <rxui:RoutedViewHost Grid.Row="1" Router="{Binding Router}" Margin="10">
      <rxui:RoutedViewHost.ViewLocator>
        <app:AppViewLocator />
      </rxui:RoutedViewHost.ViewLocator>
    </rxui:RoutedViewHost>

  </DockPanel>

</Window>
